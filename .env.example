# ─────────────────────────────────────────────
# SUPABASE
# Obtén estos valores en: https://app.supabase.com → tu proyecto → Settings → API
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────
# STRIPE
# Obtén estos valores en: https://dashboard.stripe.com → Developers → API keys
# ─────────────────────────────────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ─────────────────────────────────────────────
# RESEND
# Obtén tu clave en: https://resend.com → API Keys
# ─────────────────────────────────────────────
RESEND_API_KEY=

# ─────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────
# ADMIN
# Clave secreta para la ruta /api/admin/send-reminders
# Genera un valor largo y aleatorio (ej: openssl rand -hex 32) y ponlo
# también en los secretos de entorno de Vercel.
# ─────────────────────────────────────────────
ADMIN_API_KEY=

# ─────────────────────────────────────────────
# BUNNY.NET (video streaming protegido)
# Obtén estos valores en: https://dash.bunny.net → Stream → tu biblioteca
# BUNNY_TOKEN_AUTH_KEY es la "Token Authentication Key" de la pestaña
# Security de la biblioteca; se usa para firmar las URLs de los vídeos.
# ─────────────────────────────────────────────
BUNNY_LIBRARY_ID=
BUNNY_API_KEY=
BUNNY_TOKEN_AUTH_KEY=
